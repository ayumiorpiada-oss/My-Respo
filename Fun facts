<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Random Fun Facts</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            padding: 40px;
            max-width: 600px;
            width: 100%;
            text-align: center;
            animation: slideIn 0.5s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h1 {
            color: #333;
            margin-bottom: 30px;
            font-size: 2.5em;
        }

        .fact-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            min-height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2em;
            line-height: 1.6;
            animation: fadeIn 0.6s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .button-group {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }

        button {
            background: #667eea;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 25px;
            font-size: 1em;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
        }

        button:hover {
            background: #764ba2;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
        }

        button:active {
            transform: translateY(0);
        }

        .secondary {
            background: #e0e0e0;
            color: #333;
        }

        .secondary:hover {
            background: #d0d0d0;
        }

        .fact-counter {
            color: #666;
            font-size: 0.9em;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🎉 Fun Facts</h1>
        <div class="fact-box" id="factBox">
            Click "Get New Fact" to discover something amazing!
        </div>
        <div class="button-group">
            <button onclick="getNewFact()">Get New Fact</button>
            <button class="secondary" onclick="location.reload()">Reset</button>
        </div>
        <div class="fact-counter">
            <span id="factCount">0</span> facts revealed
        </div>
    </div>

    <script>
        const facts = [
            "🍯 Honey never spoils! Archaeologists have found 3,000-year-old honey in Egyptian tombs that was still edible.",
            "🦑 Octopuses have three hearts: two pump blood to the gills, and one pumps it to the rest of the body.",
            "🌈 A group of flamingos is called a 'flamboyance'.",
            "🧠 Your brain uses 20% of your body's energy, even though it's only 2% of your body weight.",
            "🐝 Honey bees can recognize human faces.",
            "👅 Your tongue is the only muscle that's attached on just one end.",
            "⭐ A single bolt of lightning contains enough energy to toast 100,000 slices of bread.",
            "🦖 T-Rex had such tiny arms they couldn't even touch their own mouths.",
            "🐠 Goldfish have a memory span of about 3 seconds.",
            "☀️ The sun is so large that 1.3 million Earths could fit inside it.",
            "🎸 Bananas are berries, but strawberries aren't!",
            "🧐 Wombats produce cube-shaped droppings.",
            "🌍 Venus rotates backwards compared to most planets.",
            "🦁 A group of lions is called a 'pride'.",
            "💎 Diamonds rain on Jupiter and Saturn.",
            "🐘 Elephants are the only animals that mourn their dead.",
            "🦑 The ink of a squid is edible.",
            "🌺 Flowers can grow faster while music is playing.",
            "🎯 A cat's purr vibrates at a frequency that can promote bone healing.",
            "🔥 Firefighters use Dalmatians in their logo because they used to guard horse-drawn fire engines.",
            "🐙 An octopus's blood is blue because it uses copper instead of iron.",
            "🍕 Pepperoni is America's favorite pizza topping.",
            "🧊 Penguins have knees; they're just hidden under their feathers.",
            "🐢 Sea turtles cry salt water to remove excess salt from their bodies.",
            "🌙 The Moon is moving away from Earth at about 1.5 inches per year."
        ];

        let factCount = 0;
        let lastFactIndex = -1;

        function getNewFact() {
            let randomIndex;
            
            // Ensure we don't get the same fact twice in a row
            do {
                randomIndex = Math.floor(Math.random() * facts.length);
            } while (randomIndex === lastFactIndex);
            
            lastFactIndex = randomIndex;
            const factBox = document.getElementById('factBox');
            
            // Animate out
            factBox.style.animation = 'none';
            setTimeout(() => {
                factBox.textContent = facts[randomIndex];
                factBox.style.animation = 'fadeIn 0.6s ease-out';
            }, 100);
            
            factCount++;
            document.getElementById('factCount').textContent = factCount;
        }

        // Allow Enter key to get new fact
        document.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                getNewFact();
            }
        });
    </script>
</body>
</html>
